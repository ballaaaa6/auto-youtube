# ตัวแปรสภาพแวดล้อมสำหรับ Auto YouTube

# บัญชี Cloudflare (สำหรับใช้งาน Llama 3 และ Whisper)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# ตั้งค่าเซิร์ฟเวอร์หลังบ้าน
PORT=3000
NODE_ENV=development

# ตั้งค่าการควบคุมเบราว์เซอร์ (Playwright)
# false = แสดงหน้าจอเบราว์เซอร์ (แนะนำในช่วงทดสอบและล็อกอินครั้งแรก)
# true = รันซ่อนหลังบ้าน (Headless)
HEADLESS=false

# พาธเก็บประวัติการล็อกอินเบราว์เซอร์ (Browser Sessions)
# เพื่อให้เราล็อกอิน YouTube และ Google Flow เพียงครั้งเดียวแล้วบอทจำไปใช้ต่อได้
BROWSER_PROFILE_PATH=../profiles/user_data

# ตั้งค่า Named Cloudflare Tunnel (ตัวเลือกเสริมสำหรับข้ามหน้าจอแจ้งเตือนความปลอดภัยเมื่อรันระยะไกล)
# CLOUDFLARE_TUNNEL_TOKEN=your_named_tunnel_token
# CLOUDFLARE_TUNNEL_URL=https://your-custom-subdomain.yourdomain.com
